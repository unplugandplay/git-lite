#!/bin/bash
# git-lite - A Git-like version control system backed by SQLite
# Wrapper script to handle gem environment issues

# Use system Ruby and clear problematic environment variables
unset GEM_HOME
unset GEM_PATH
unset RUBYOPT
unset RUBYLIB

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

exec /usr/bin/ruby -I "$SCRIPT_DIR/../lib" "$SCRIPT_DIR/git-lite.rb" "$@"
